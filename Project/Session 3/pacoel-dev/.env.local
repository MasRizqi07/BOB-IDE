# ─────────────────────────────────────────────────────────
# Pacoel.Dev — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────

# Site URL (used for og metadata + canonical links)
NEXT_PUBLIC_SITE_URL=https://pacoel.dev

# Contact form — replace mailto: fallback with a real email API
# Option A: Resend
RESEND_API_KEY=

# Option B: Formspree endpoint (no backend needed)
NEXT_PUBLIC_FORMSPREE_ID=
